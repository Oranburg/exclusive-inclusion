{\*\bkmkstart co_fnRef_F28482421465_ID0ESYAE_1}{\*\bkmkend co_fnRef_F28482421465_ID0ESYAE_1}
{\field {\*\fldinst HYPERLINK "#co_footnote_F28482421465_1" }{\fldrslt 
