}
{\field {\*\fldinst HYPERLINK "https://www.westlaw.com/Link/Document/FullText?findType=Y&serNum=2003444559&pubNum=708&originatingDoc=Ic2740c37541211d9b17ee4cdc604a702&refType=RP&fi=co_pp_sp_708_2339&originationContext=document&vr=3.0&rs=cblt1.0&transitionType=DocumentItem&contextData=(sc.DocLink)#co_pp_sp_708_2339" }{\fldrslt 
