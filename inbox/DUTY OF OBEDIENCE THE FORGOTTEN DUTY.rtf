{\*\bkmkstart co_fnRef_F27357692861_ID0E5UAE_1}{\*\bkmkend co_fnRef_F27357692861_ID0E5UAE_1}
{\field {\*\fldinst HYPERLINK "#co_footnote_F27357692861_1" }{\fldrslt 
